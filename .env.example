# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
# Get from https://console.neon.tech → Connection Details
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@HOST-UNPOOLED/neondb?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@HOST-UNPOOLED/neondb?sslmode=require
REALTIME_DATABASE_URL=postgresql://USER:PASSWORD@HOST-UNPOOLED/neondb?sslmode=require

# ─── Clinic ───────────────────────────────────────────────────────────────────
DEFAULT_CLINIC_ID=00000000-0000-0000-0000-000000000001

# ─── Clerk Authentication ─────────────────────────────────────────────────────
# Get from https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk Routes
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/patient/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/patient/profile
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/patient/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/patient/profile

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
