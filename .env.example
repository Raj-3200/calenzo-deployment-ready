# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/patient/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/patient/register
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/patient/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/patient/profile
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/patient/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/patient/profile
CLERK_WEBHOOK_SIGNING_SECRET=

# Database
DATABASE_URL=
DIRECT_URL=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
DEFAULT_CLINIC_ID=00000000-0000-0000-0000-000000000001
ADMIN_EMAIL=admin@calenzo.health
ADMIN_PASSWORD=Admin1234!
ADMIN_ROLE=OWNER
ADMIN_SESSION_SECRET=
GEMINI_API_KEY=

# Real-time queue
# Calenzo uses PostgreSQL LISTEN/NOTIFY with SSE. Use an unpooled URL here when available.
REALTIME_DATABASE_URL=
DATABASE_URL_UNPOOLED=

# Pusher-compatible fallback placeholders
PUSHER_APP_ID=
PUSHER_APP_KEY=
NEXT_PUBLIC_PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=

# WhatsApp (optional, Twilio or similar)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
# Approved WhatsApp template for automatic appointment ticket notifications.
# Required for production outbound messages to patients who have not messaged the clinic first.
TWILIO_WHATSAPP_CONTENT_SID=

# Email / webhooks (optional)
EMAIL_FROM=
RESEND_API_KEY=
WEBHOOK_SECRET=
